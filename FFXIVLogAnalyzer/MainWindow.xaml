<Window x:Class="FFXIVLogAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:converters="clr-namespace:FFXIVLogAnalyzer.Converters"
        Title="{Binding WindowTitle}" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Foreground="#CDD6F4">
    <Window.Resources>
        <converters:HighlightStateToBackgroundConverter x:Key="HighlightBgConv"/>
        <converters:HighlightStateToDecorationConverter x:Key="HighlightDecConv"/>
        <converters:DeltaToColorConverter x:Key="DeltaColorConv"/>
        <Style x:Key="DarkDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="RowBackground" Value="#1E1E2E"/>
            <Setter Property="AlternatingRowBackground" Value="#181825"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#313244"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
        </Style>
        <Style x:Key="DarkColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#181825" Padding="8" BorderBrush="#313244" BorderThickness="0,0,0,1">
            <WrapPanel>
<!-- PLACEHOLDER_TOOLBAR_BUTTONS -->
                <Button Content="打开日志" Command="{Binding OpenLogCommand}" Margin="0,0,8,0"
                        Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold" Padding="12,6" BorderThickness="0"/>
                <Button Content="导出时间轴" Command="{Binding ExportTimelineCommand}" Margin="0,0,8,0"
                        Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold" Padding="12,6" BorderThickness="0"/>
                <Button Content="查看原始日志" Click="OpenRawLogWindow_Click" Margin="0,0,8,0"
                        Background="#CBA6F7" Foreground="#1E1E2E" FontWeight="Bold" Padding="12,6" BorderThickness="0"/>
                <Button Content="复制选中Boss技能ID" Click="CopyBossSkillId_Click" Margin="0,0,16,0"
                        Background="#F9E2AF" Foreground="#1E1E2E" FontWeight="Bold" Padding="12,6" BorderThickness="0"/>
                <TextBlock Text="战斗场次:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#A6ADC8"/>
                <ComboBox ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}"
                          DisplayMemberPath="DisplayName"
                          Width="280" Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Margin="0,0,16,0"/>
                <TextBlock Text="Boss筛选:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#A6ADC8"/>
                <ComboBox ItemsSource="{Binding BossNameFilters}" SelectedItem="{Binding SelectedBossFilter}"
                          Width="180" Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Margin="0,0,8,0"/>
                <TextBlock Text="玩家:" VerticalAlignment="Center" Margin="8,0,4,0" Foreground="#A6ADC8"/>
                <ComboBox ItemsSource="{Binding PlayerNameFilters}" SelectedItem="{Binding SelectedPlayerFilter}"
                          Width="120" Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Margin="0,0,8,0"/>
                <CheckBox Content="仅自己(Request)" IsChecked="{Binding RequestOnly}" VerticalAlignment="Center"
                          Margin="8,0,0,0" Foreground="#CDD6F4"/>
                <CheckBox Content="隐藏已忽略" IsChecked="{Binding HideIgnored}" VerticalAlignment="Center"
                          Margin="8,0,0,0" Foreground="#CDD6F4"/>
            </WrapPanel>
        </Border>
<!-- PLACEHOLDER_MAIN_AREA -->
        <!-- Main 3-column area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Boss Timeline -->
            <Border Grid.Column="0" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Boss 时间轴" Padding="8,6" Background="#313244" Foreground="#F5C2E7" FontWeight="Bold" FontSize="13"/>
                    <TextBox Grid.Row="1" Text="{Binding BossSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="6,4"
                             Tag="搜索技能名或ID..."/>
                    <DataGrid x:Name="BossGrid" Grid.Row="2" Style="{StaticResource DarkDataGrid}" ColumnHeaderStyle="{StaticResource DarkColumnHeader}"
                              ItemsSource="{Binding FilteredBossSkills}" SelectedItem="{Binding SelectedBossSkill}"
                              MouseDoubleClick="BossGrid_MouseDoubleClick"
                              PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding DisplayTime}" Width="90"/>
                            <DataGridTextColumn Header="ID" Binding="{Binding SkillId}" Width="55">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#F9E2AF"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="技能名" Binding="{Binding SkillName}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#F38BA8"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="读条" Binding="{Binding CastTimeDisplay}" Width="50"/>
                            <DataGridTextColumn Header="Boss" Binding="{Binding BossName}" Width="85"/>
                            <DataGridTextColumn Header="可选中" Binding="{Binding TargetableDisplay}" Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTargetable}" Value="True">
                                                <Setter Property="Foreground" Value="#A6E3A1"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsTargetable}" Value="False">
                                                <Setter Property="Foreground" Value="#F38BA8"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="跳转到原始日志" Click="JumpBossToLog_Click"/>
                                <MenuItem Header="复制技能ID" Click="CopyBossSkillId_Click"/>
                                <MenuItem Header="复制技能名" Click="CopyBossSkillName_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="#313244" HorizontalAlignment="Center"/>

            <!-- Center: Player Skills + Boss Effects -->
            <Grid Grid.Column="2" Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Player Skills -->
                <Border Grid.Row="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="玩家技能 (±10秒)" Padding="8,6" Background="#313244" Foreground="#89B4FA" FontWeight="Bold" FontSize="13"/>
                        <DataGrid x:Name="PlayerSkillGrid" Grid.Row="1" Style="{StaticResource DarkDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DarkColumnHeader}"
                                  ItemsSource="{Binding NearbyPlayerSkills}"
                                  MouseDoubleClick="PlayerSkillGrid_MouseDoubleClick"
                                  PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="{Binding HighlightState, Converter={StaticResource HighlightBgConv}}"/>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding DisplayTime}" Width="90"/>
                                <DataGridTextColumn Header="Delta" Binding="{Binding DeltaDisplay}" Width="65">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding DeltaSeconds, Converter={StaticResource DeltaColorConv}}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="技能" Binding="{Binding DisplayName}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextDecorations" Value="{Binding HighlightState, Converter={StaticResource HighlightDecConv}}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="ID" Binding="{Binding SkillId}" Width="55"/>
                                <DataGridTextColumn Header="玩家" Binding="{Binding PlayerName}" Width="75"/>
                                <DataGridTextColumn Header="类型" Binding="{Binding EventType}" Width="55"/>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="跳转到原始日志" Click="JumpPlayerToLog_Click"/>
                                    <MenuItem Header="复制技能ID" Click="CopyPlayerSkillId_Click"/>
                                    <MenuItem Header="复制技能名" Click="CopyPlayerSkillName_Click"/>
                                    <MenuItem Header="复制Delta值" Click="CopyDelta_Click"/>
                                    <Separator/>
                                    <MenuItem Header="查询距离Boss机制时间..." Click="QueryDistanceToBoss_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="#313244"/>

                <!-- Boss Effects -->
                <Border Grid.Row="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Boss效果命中 (±15秒)" Padding="8,6" Background="#313244" Foreground="#FAB387" FontWeight="Bold" FontSize="13"/>
                        <TextBox Grid.Row="1" Text="{Binding EffectSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="6,4"
                                 Tag="搜索技能名/ID/目标名..."/>
                        <DataGrid x:Name="EffectGrid" Grid.Row="2" Style="{StaticResource DarkDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DarkColumnHeader}"
                                  ItemsSource="{Binding NearbyBossEffects}"
                                  SelectedItem="{Binding SelectedBossEffect}"
                                  MouseDoubleClick="EffectGrid_MouseDoubleClick"
                                  PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding DisplayTime}" Width="90"/>
                                <DataGridTextColumn Header="Delta" Binding="{Binding DeltaDisplay}" Width="65">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding DeltaSeconds, Converter={StaticResource DeltaColorConv}}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="ID" Binding="{Binding ActionId}" Width="55">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#F9E2AF"/></Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="技能名" Binding="{Binding ActionName}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FAB387"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="目标" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent" ToolTip="{Binding TargetTooltip}">
                                                <TextBlock Text="{Binding TargetDisplay}" Padding="2,0"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="来源" Binding="{Binding SourceName}" Width="80"/>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="跳转到原始日志" Click="JumpEffectToLog_Click"/>
                                    <MenuItem Header="复制ActionID" Click="CopyEffectId_Click"/>
                                    <MenuItem Header="复制技能名" Click="CopyEffectName_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" Background="#313244" HorizontalAlignment="Center"/>

            <!-- Right: Skill Mapping -->
            <Border Grid.Column="4" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="技能ID映射" Padding="8,6" Background="#313244" Foreground="#A6E3A1" FontWeight="Bold" FontSize="13"/>
                    <DataGrid Grid.Row="1" Style="{StaticResource DarkDataGrid}" ColumnHeaderStyle="{StaticResource DarkColumnHeader}"
                              ItemsSource="{Binding SkillMappings}" IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="技能ID" Binding="{Binding SkillId}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="自定义名称" Binding="{Binding CustomName, UpdateSourceTrigger=PropertyChanged}" Width="*" IsReadOnly="False">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#F9E2AF"/></Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="#313244"/>
                                        <Setter Property="Foreground" Value="#F9E2AF"/>
                                        <Setter Property="BorderBrush" Value="#89B4FA"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Grid.Row="2" Content="应用映射" Command="{Binding ApplyMappingsCommand}"
                            Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold" Padding="12,8"
                            Margin="4" BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#181825" Padding="8,4" BorderBrush="#313244" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="#A6ADC8" FontSize="12"/>
        </Border>
    </Grid>
</Window>
